# ========================================
# BANCOLOMBIA - RAILWAY DEPLOYMENT CONFIG
# ========================================

# Application Environment (Railway optimized - zero delays)
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=America/Bogota
APP_URL=${RAILWAY_STATIC_URL}

# Telegram Configuration (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Session Configuration (optimized for performance)
SESSION_LIFETIME=3600
SESSION_PATH=storage/sessions

# Logging (minimal for performance)
LOG_LEVEL=error
LOG_PATH=storage/logs/app.log

# Performance (Railway auto-sets PORT variable)
PORT=${PORT}
