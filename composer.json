{
    "name": "bancolombia/sucursal-negocios",
    "description": "Sistema Bancolombia Sucursal Virtual Negocios - Arquitectura Clean con PHP 8.1+",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-session": "*",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.5"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "phpcs": "phpcs --standard=PSR12 src/",
        "phpstan": "phpstan analyse src/",
        "check": [
            "@phpcs",
            "@phpstan"
        ]
    }
}